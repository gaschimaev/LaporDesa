{
    "containerDefinitions": [
        {
            "name": "lapordesa-app",
            "image": "414061811035.dkr.ecr.ap-southeast-2.amazonaws.com/lapordesa",
            "cpu": 0,
            "portMappings": [
                {
                    "containerPort": 80,
                    "hostPort": 80,
                    "protocol": "tcp",
                    "name": "lapordesa-app-80-tcp",
                    "appProtocol": "http"
                }
            ],
            "essential": true,
            "environment": [
                {
                    "name": "DB_NAME",
                    "value": "lapordesa"
                },
                {
                    "name": "CLOUDFRONT_DOMAIN",
                    "value": "d1dn0toqpnv8xt.cloudfront.net"
                },
                {
                    "name": "S3_BUCKET_NAME",
                    "value": "lapordesa-bucket-nimanda"
                },
                {
                    "name": "DB_HOST",
                    "value": "db-lapordesa.cvmi6m8k88z0.ap-southeast-2.rds.amazonaws.com"
                },
                {
                    "name": "DB_USER",
                    "value": "admin"
                },
                {
                    "name": "DB_PASSWORD",
                    "value": "admin123"
                }
            ],
            "environmentFiles": [],
            "mountPoints": [],
            "volumesFrom": [],
            "ulimits": [],
            "logConfiguration": {
                "logDriver": "awslogs",
                "options": {
                    "awslogs-group": "/ecs/lapordesa-task",
                    "awslogs-create-group": "true",
                    "awslogs-region": "ap-southeast-2",
                    "awslogs-stream-prefix": "ecs"
                },
                "secretOptions": []
            },
            "systemControls": []
        }
    ],
    "family": "lapordesa-task",
    "taskRoleArn": "arn:aws:iam::414061811035:role/ECS-role-3a07153b",
    "executionRoleArn": "arn:aws:iam::414061811035:role/ECS-role-3a07153b",
    "networkMode": "awsvpc",
    "volumes": [],
    "placementConstraints": [],
    "runtimePlatform": {
        "cpuArchitecture": "X86_64",
        "operatingSystemFamily": "LINUX"
    },
    "requiresCompatibilities": [
        "FARGATE"
    ],
    "cpu": "256",
    "memory": "512",
    "tags": []
}